// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  nom       String
  role      Role     @default(USER)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}

enum Role {
  ADMIN
  USER

  @@map("role")
}

model Client {
  id        Int        @id @default(autoincrement())
  nom       String
  adresse   String?
  tel       String?
  email     String?
  pays      String     @default("Gabon")
  createdAt DateTime   @default(now()) @map("created_at")
  documents Document[]

  @@map("clients")
}

model Produit {
  id              Int              @id @default(autoincrement())
  code            String           @unique
  label           String
  prix            Decimal          @db.Decimal(15, 2)
  categorie       String
  description     String?
  actif           Boolean          @default(true)
  createdAt       DateTime         @default(now()) @map("created_at")
  lignesDocument  LigneDocument[]

  @@index([code])
  @@index([categorie])
  @@map("produits")
}

model Document {
  id                   Int             @id @default(autoincrement())
  type                 TypeDocument
  numero               String          @unique
  clientId             Int             @map("client_id")
  client               Client          @relation(fields: [clientId], references: [id], onDelete: Restrict)
  date                 DateTime        @db.Date
  reference            String?
  soldeHt              Decimal         @map("solde_ht") @db.Decimal(15, 2)
  remise               Decimal         @default(0) @db.Decimal(15, 2)
  sousTotal            Decimal         @map("sous_total") @db.Decimal(15, 2)
  tps                  Decimal         @db.Decimal(15, 2)
  css                  Decimal         @db.Decimal(15, 2)
  netAPayer            Decimal         @map("net_a_payer") @db.Decimal(15, 2)
  soldeDu              Decimal         @map("solde_du") @db.Decimal(15, 2)
  statut               StatutDocument  @default(ACTIVE)
  conditionsPaiement   String?         @map("conditions_paiement")
  createdAt            DateTime        @default(now()) @map("created_at")
  lignes               LigneDocument[]

  @@index([clientId])
  @@index([date])
  @@index([type])
  @@map("documents")
}

enum TypeDocument {
  DEVIS
  FACTURE
  AVOIR

  @@map("type_document")
}

enum StatutDocument {
  ACTIVE
  PAYEE
  ANNULEE

  @@map("statut_document")
}

model LigneDocument {
  id           Int      @id @default(autoincrement())
  documentId   Int      @map("document_id")
  document     Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  produitId    Int      @map("produit_id")
  produit      Produit  @relation(fields: [produitId], references: [id], onDelete: Restrict)
  designation  String
  quantite     Int
  prixUnitaire Decimal  @map("prix_unitaire") @db.Decimal(15, 2)
  totalHt      Decimal  @map("total_ht") @db.Decimal(15, 2)

  @@index([documentId])
  @@map("lignes_document")
}

model Parametres {
  id            Int     @id @default(1)
  nomEntreprise String  @default("SING S.A.") @map("nom_entreprise")
  adresse       String  @default("BP. 2280, Centre Ville, Libreville – Gabon")
  telephone     String  @default("+241 74 13 71 03")
  email         String  @default("info@sing.ga")
  siteWeb       String  @default("https://www.sing.ga/") @map("site_web")
  rccm          String  @default("RG LBV 2018B22204")
  capital       String  @default("50 000 000 FCFA")
  tauxTps       Decimal @default(0.095) @map("taux_tps") @db.Decimal(5, 4)
  tauxCss       Decimal @default(0.01) @map("taux_css") @db.Decimal(5, 4)
  tauxTva       Decimal @default(0.18) @map("taux_tva") @db.Decimal(5, 4)
  tauxRemise    Decimal @default(0.095) @map("taux_remise") @db.Decimal(5, 4)
  ribUba        String  @default("40025 05801 80100300296 81") @map("rib_uba")
  ribAfg        String  @default("40001 09070 07000615101 36") @map("rib_afg")

  @@map("parametres")
}
