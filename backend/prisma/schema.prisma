// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organisation {
  id                  Int      @id @default(autoincrement())
  nom                 String
  email               String   @unique
  telephone           String?
  adresse             String?
  ville               String?
  pays                String   @default("Gabon")
  rccm                String?
  numStatistique      String?  @map("num_statistique")
  numImpot            String?  @map("num_impot")
  capital             String?
  formeJuridique      String?  @map("forme_juridique")
  secteurActivite     String?  @map("secteur_activite")
  siteWeb             String?  @map("site_web")
  logo                String?
  actif               Boolean  @default(true)
  dateExpiration      DateTime? @map("date_expiration")
  plan                Plan     @default(STARTER)
  createdAt           DateTime @default(now()) @map("created_at")
  users               User[]
  clients             Client[]
  produits            Produit[]
  documents           Document[]
  parametres          Parametres?

  @@map("organisations")
}

enum Plan {
  STARTER
  PRO
  ENTREPRISE

  @@map("plan")
}

model User {
  id             Int           @id @default(autoincrement())
  email          String        @unique
  password       String
  nom            String
  telephone      String?
  role           Role          @default(ADMIN)
  organisationId Int           @map("organisation_id")
  organisation   Organisation  @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now()) @map("created_at")

  @@index([organisationId])
  @@map("users")
}

enum Role {
  ADMIN
  USER

  @@map("role")
}

model Client {
  id             Int           @id @default(autoincrement())
  nom            String        // Nom de l'organisation cliente
  adresse        String?
  tel            String?       // Téléphone principal de l'organisation
  email          String?       // Email principal de l'organisation
  pays           String        @default("Gabon")
  organisationId Int           @map("organisation_id")
  organisation   Organisation  @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now()) @map("created_at")
  documents      Document[]
  representants  Representant[] // Personnes de contact du client

  @@index([organisationId])
  @@map("clients")
}

// Représentants (personnes de contact) d'un client
model Representant {
  id        Int      @id @default(autoincrement())
  clientId  Int      @map("client_id")
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  nom       String   // Nom complet du représentant
  fonction  String?  // Poste/Fonction (ex: Directeur, Responsable Achats)
  tel       String?  // Téléphone direct du représentant
  email     String?  // Email du représentant
  principal Boolean  @default(false) // Représentant principal
  createdAt DateTime @default(now()) @map("created_at")

  @@index([clientId])
  @@map("representants")
}

model Produit {
  id              Int              @id @default(autoincrement())
  code            String
  label           String
  prix            Decimal          @db.Decimal(15, 2)
  categorie       String
  description     String?
  actif           Boolean          @default(true)
  organisationId  Int              @map("organisation_id")
  organisation    Organisation     @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  createdAt       DateTime         @default(now()) @map("created_at")
  lignesDocument  LigneDocument[]

  @@unique([code, organisationId])
  @@index([organisationId])
  @@index([categorie])
  @@map("produits")
}

model Document {
  id                   Int             @id @default(autoincrement())
  type                 TypeDocument
  numero               String
  clientId             Int             @map("client_id")
  client               Client          @relation(fields: [clientId], references: [id], onDelete: Restrict)
  organisationId       Int             @map("organisation_id")
  organisation         Organisation    @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  date                 DateTime        @db.Date
  reference            String?
  soldeHt              Decimal         @map("solde_ht") @db.Decimal(15, 2)
  remise               Decimal         @default(0) @db.Decimal(15, 2)
  sousTotal            Decimal         @map("sous_total") @db.Decimal(15, 2)
  tps                  Decimal         @db.Decimal(15, 2)
  css                  Decimal         @db.Decimal(15, 2)
  netAPayer            Decimal         @map("net_a_payer") @db.Decimal(15, 2)
  soldeDu              Decimal         @map("solde_du") @db.Decimal(15, 2)
  statut               StatutDocument  @default(ACTIVE)
  conditionsPaiement   String?         @map("conditions_paiement")
  createdAt            DateTime        @default(now()) @map("created_at")
  lignes               LigneDocument[]

  @@unique([numero, organisationId])
  @@index([clientId])
  @@index([organisationId])
  @@index([date])
  @@index([type])
  @@map("documents")
}

enum TypeDocument {
  DEVIS
  COMMANDE
  LIVRAISON
  FACTURE
  AVOIR

  @@map("type_document")
}

enum StatutDocument {
  ACTIVE
  PAYEE
  ANNULEE

  @@map("statut_document")
}

model LigneDocument {
  id           Int      @id @default(autoincrement())
  documentId   Int      @map("document_id")
  document     Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  produitId    Int      @map("produit_id")
  produit      Produit  @relation(fields: [produitId], references: [id], onDelete: Restrict)
  designation  String
  quantite     Int
  prixUnitaire Decimal  @map("prix_unitaire") @db.Decimal(15, 2)
  totalHt      Decimal  @map("total_ht") @db.Decimal(15, 2)

  @@index([documentId])
  @@map("lignes_document")
}

model Parametres {
  id             Int          @id @default(autoincrement())
  organisationId Int          @unique @map("organisation_id")
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  nomEntreprise  String       @default("Mon Entreprise") @map("nom_entreprise")
  adresse        String       @default("")
  telephone      String       @default("")
  email          String       @default("")
  siteWeb        String       @default("") @map("site_web")
  rccm           String       @default("")
  capital        String       @default("")
  tauxTps        Decimal      @default(0.095) @map("taux_tps") @db.Decimal(5, 4)
  tauxCss        Decimal      @default(0.01) @map("taux_css") @db.Decimal(5, 4)
  tauxTva        Decimal      @default(0.18) @map("taux_tva") @db.Decimal(5, 4)
  tauxRemise     Decimal      @default(0.095) @map("taux_remise") @db.Decimal(5, 4)
  ribUba         String       @default("") @map("rib_uba")
  ribAfg         String       @default("") @map("rib_afg")

  @@map("parametres")
}

// Templates PDF pour génération de documents
model PdfTemplate {
  id              Int          @id @default(autoincrement())
  organisationId  Int          @map("organisation_id")
  nom             String       // Nom du template (ex: "Facture Standard", "Devis Moderne")
  type            TypeDocument // Type de document (DEVIS, FACTURE, etc.)
  fichierOriginal String       @map("fichier_original") // Chemin du PDF uploadé
  
  // Styles extraits automatiquement
  couleurPrimaire String?      @map("couleur_primaire") // Couleur dominante (hex)
  couleurSecondaire String?    @map("couleur_secondaire")
  couleurTexte    String?      @map("couleur_texte")
  police          String?      // Police principale détectée
  
  // Configuration de mise en page
  marges          Json?        // {top: 50, right: 50, bottom: 50, left: 50}
  sections        Json?        // Configuration des sections du document
  
  actif           Boolean      @default(true)
  parDefaut       Boolean      @default(false) @map("par_defaut") // Template par défaut pour ce type
  
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  @@index([organisationId])
  @@index([type])
  @@map("pdf_templates")
}

// Système de PACKS (codes produits avec sous-services)
model Pack {
  id              Int          @id @default(autoincrement())
  code            String
  descCourte      String       @map("desc_courte")
  prixUnitaire    Decimal      @map("prix_unitaire") @db.Decimal(15, 2)
  sousService     String       @map("sous_service")
  organisationId  Int          @map("organisation_id")
  actif           Boolean      @default(true)
  createdAt       DateTime     @default(now()) @map("created_at")
  details         PackDetail[]

  @@unique([code, organisationId])
  @@index([organisationId])
  @@index([sousService])
  @@map("packs")
}

// Détails des PACKS (lignes de description)
model PackDetail {
  id              Int      @id @default(autoincrement())
  packId          Int      @map("pack_id")
  pack            Pack     @relation(fields: [packId], references: [id], onDelete: Cascade)
  ordre           Int      @default(0)
  descriptionLongue String @map("description_longue")

  @@index([packId])
  @@map("pack_details")
}

// Récapitulatif des factures (vue consolidée)
model Recapitulatif {
  id                Int      @id @default(autoincrement())
  organisationId    Int      @map("organisation_id")
  documentId        Int?     @map("document_id")
  dateFacture       DateTime @map("date_facture") @db.Date
  designation       String
  numeroFacture     String   @map("numero_facture")
  numeroBc          String?  @map("numero_bc")
  
  // Montants par sous-service (colonnes dynamiques)
  montantServices   Json     @map("montant_services") // {"Assistance informatique": 50000, "Formation": 30000}
  
  // Totaux
  soldeHt           Decimal  @map("solde_ht") @db.Decimal(15, 2)
  remise            Decimal  @default(0) @db.Decimal(15, 2)
  sousTotal2        Decimal  @map("sous_total_2") @db.Decimal(15, 2)
  tps               Decimal  @db.Decimal(15, 2)
  css               Decimal  @db.Decimal(15, 2)
  netAPayer         Decimal  @map("net_a_payer") @db.Decimal(15, 2)
  
  // Règlement
  reglement         Decimal? @db.Decimal(15, 2)
  soldeDu           Decimal? @map("solde_du") @db.Decimal(15, 2)
  dateReglement     DateTime? @map("date_reglement") @db.Date
  
  // Statut
  etat              StatutDocument @default(ACTIVE)
  
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([organisationId])
  @@index([dateFacture])
  @@index([numeroFacture])
  @@map("recapitulatif")
}
